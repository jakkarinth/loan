# Copy this file to .env before running docker compose.

NODE_ENV=production

# Frontend
NEXT_PUBLIC_APP_NAME="ระบบบริหารลูกหนี้เงินยืม RMUTI Surin"
NEXT_PUBLIC_API_BASE_URL=http://203.158.199.59:4000/api
API_INTERNAL_BASE_URL=http://backend:4000/api
NEXTAUTH_URL=http://203.158.199.59:3000
NEXTAUTH_SECRET=replace-with-secure-nextauth-secret

# Backend
PORT=4000
CLIENT_ORIGIN=http://203.158.199.59:3000
JWT_SECRET=replace-with-secure-jwt-secret
JWT_EXPIRES_IN=1d

# MySQL on Docker host:
# - Use host.docker.internal from app containers.
# - MySQL must allow remote/container connections.
DB_HOST=host.docker.internal
DB_PORT=3306
DB_USER=loan_user
DB_PASSWORD=replace-with-db-password
DB_NAME=rmuti_surin_loan
