# Shared
NODE_ENV=development

# Frontend
NEXT_PUBLIC_APP_NAME="ระบบบริหารลูกหนี้เงินยืม RMUTI Surin"
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=replace-with-secure-secret

# Backend
PORT=4000
CLIENT_ORIGIN=http://localhost:3000
JWT_SECRET=replace-with-secure-jwt-secret
JWT_EXPIRES_IN=1d

# MySQL
# Docker deploy with MySQL on the Docker host: use DB_HOST=host.docker.internal and DB_PORT=3306.
# Docker deploy with the compose mysql profile: use DB_HOST=mysql and DB_PORT=3306.
# Local host without Docker app containers may use DB_HOST=localhost.
DB_HOST=localhost
DB_PORT=3307
DB_USER=loan_user
DB_PASSWORD=loan_password
DB_NAME=rmuti_surin_loan
